<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FutbolManagerMobil.LeaguePage"
             BackgroundColor="#0D0D0D"
             Title="Puan Durumu">

    <Grid RowDefinitions="Auto, Auto, *, Auto" Padding="16,20,16,16" RowSpacing="12">

        <!-- BAŞLIK -->
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="🏆 LİG PUAN DURUMU" FontSize="22" FontAttributes="Bold"
                   TextColor="Gold" HorizontalOptions="Center"/>
            <BoxView HeightRequest="1" Color="Gold" Opacity="0.4" Margin="30,4"/>
        </VerticalStackLayout>

        <!-- TABLO BAŞLIKLARI -->
        <Border Grid.Row="1" BackgroundColor="#1A1A1A"
                StrokeShape="RoundRectangle 10" Stroke="#333333" Padding="10,8">
            <Grid ColumnDefinitions="3*, *, *, *, *, *, *, *, 1.5*" ColumnSpacing="2">
                <Label Grid.Column="0" Text="TAKIM"  TextColor="Gold" FontAttributes="Bold" FontSize="11"/>
                <Label Grid.Column="1" Text="O"      TextColor="#AAAAAA" FontAttributes="Bold" FontSize="11" HorizontalOptions="Center"/>
                <Label Grid.Column="2" Text="G"      TextColor="#44FF44" FontAttributes="Bold" FontSize="11" HorizontalOptions="Center"/>
                <Label Grid.Column="3" Text="B"      TextColor="#FFAA00" FontAttributes="Bold" FontSize="11" HorizontalOptions="Center"/>
                <Label Grid.Column="4" Text="M"      TextColor="#FF4444" FontAttributes="Bold" FontSize="11" HorizontalOptions="Center"/>
                <Label Grid.Column="5" Text="AG"     TextColor="#AAAAAA" FontAttributes="Bold" FontSize="11" HorizontalOptions="Center"/>
                <Label Grid.Column="6" Text="YG"     TextColor="#AAAAAA" FontAttributes="Bold" FontSize="11" HorizontalOptions="Center"/>
                <Label Grid.Column="7" Text="AV"     TextColor="#AAAAAA" FontAttributes="Bold" FontSize="11" HorizontalOptions="Center"/>
                <Label Grid.Column="8" Text="P"      TextColor="Gold"    FontAttributes="Bold" FontSize="13" HorizontalOptions="Center"/>
            </Grid>
        </Border>

        <!-- LİG TABLOSU (dinamik) -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout x:Name="slTablo" Spacing="4"/>
        </ScrollView>

        <!-- BUTONLAR -->
        <Grid Grid.Row="3" ColumnDefinitions="*, *" ColumnSpacing="10">
            <Button Grid.Column="0"
                    Text="🔄 Ligi Sıfırla"
                    Clicked="OnLigiSifirlaClicked"
                    BackgroundColor="#5C1A1A"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="50"/>
            <Button Grid.Column="1"
                    Text="🏠 Ana Menüye Dön"
                    Clicked="OnAnaMenuyeDonClicked"
                    BackgroundColor="#1A3A5C"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="50"/>
        </Grid>

    </Grid>
</ContentPage>
