<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FutbolManagerMobil"
             x:Class="FutbolManagerMobil.MainPage"
             BackgroundColor="#121212"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, 5*, 4*" Padding="8" RowSpacing="6">

        <!-- ── SKOR BAŞLIĞI ── -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto, *"
              BackgroundColor="#1A1A1A" Padding="6,5" ColumnSpacing="4">
            <Label Grid.Column="0" x:Name="lblEvTakimAd"
                   Text="EV" TextColor="Gold" FontSize="18" FontAttributes="Bold"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <Label Grid.Column="1" x:Name="lblSkor"
                   Text="0 - 0" TextColor="White" FontSize="22" FontAttributes="Bold"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <Label Grid.Column="2" x:Name="lblDakika"
                   Text="1'" TextColor="Gold" FontSize="15" FontAttributes="Bold"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
            <Grid Grid.Column="3" ColumnDefinitions="*, Auto">
                <Label Grid.Column="0" x:Name="lblDepTakimAd"
                       Text="DEP" TextColor="Cyan" FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
                <Button Grid.Column="1" Text="📊"
                        Clicked="OnPuanDurumuClicked"
                        FontSize="16" BackgroundColor="Transparent"
                        WidthRequest="38" HeightRequest="38" Padding="0"/>
            </Grid>
        </Grid>

        <!-- ── SAHA + SPİKER ── -->
        <Grid Grid.Row="1" ColumnDefinitions="2.2*, 1*" ColumnSpacing="6">
            <Border Grid.Column="0" Stroke="White" StrokeThickness="1"
                    BackgroundColor="#1E5D1E" StrokeShape="RoundRectangle 4">
                <GraphicsView x:Name="sahaGrafik"/>
            </Border>
            <Border Grid.Column="1" BackgroundColor="#121212" Padding="6"
                    StrokeShape="RoundRectangle 8" Stroke="#444444">
                <ScrollView x:Name="scrSpiker">
                    <VerticalStackLayout x:Name="slSpiker" Spacing="4">
                        <Label x:Name="lblSpiker"
                               Text="⚽ Maç başlıyor..."
                               TextColor="#FFFFFF" FontSize="15"
                               FontAttributes="Bold" LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <!-- ── KONTROL PANELİ ── -->
        <Grid Grid.Row="2" RowDefinitions="*">

            <!-- Normal Hamle Paneli:
                 Sol = Ev Sahibi (DAIMA), Sağ = Deplasman (DAIMA) -->
            <Grid x:Name="pnlNormalHamle" ColumnDefinitions="*, *" ColumnSpacing="8">

                <!-- EV SAHİBİ PANELİ (Sol — Sabit) -->
                <Grid Grid.Column="0" RowDefinitions="Auto, Auto, *, *, *" RowSpacing="5">
                    <!-- Başlık: Ev takım adı daima burada -->
                    <Label Grid.Row="0" x:Name="lblEvPanelBaslik"
                           Text="EV SAHİBİ" TextColor="Gold" FontSize="14"
                           FontAttributes="Bold" HorizontalOptions="Center"/>
                    <!-- Aktif oyuncu ismi (hücum veya savunma) -->
                    <Label Grid.Row="1" x:Name="lblEvOyuncu"
                           Text="⚽ —" TextColor="#CCCCCC" FontSize="12"
                           HorizontalOptions="Center"/>

                    <Button Grid.Row="2" x:Name="btnEv1"
                            Text="—" Clicked="HamleEvClicked"
                            FontSize="19" FontAttributes="Bold" TextColor="White"
                            BackgroundColor="#2A4A2A" CornerRadius="8"
                            HeightRequest="60" Padding="0"/>
                    <Button Grid.Row="3" x:Name="btnEv2"
                            Text="—" Clicked="HamleEvClicked"
                            FontSize="19" FontAttributes="Bold" TextColor="White"
                            BackgroundColor="#2A3A4A" CornerRadius="8"
                            HeightRequest="60" Padding="0"/>
                    <Button Grid.Row="4" x:Name="btnEv3"
                            Text="—" Clicked="HamleEvClicked"
                            FontSize="19" FontAttributes="Bold" TextColor="White"
                            BackgroundColor="#8B1A1A" CornerRadius="8"
                            HeightRequest="65" Padding="0"/>
                </Grid>

                <!-- DEPLASMAN PANELİ (Sağ — Sabit) -->
                <Grid Grid.Column="1" RowDefinitions="Auto, Auto, *, *, *" RowSpacing="5">
                    <Label Grid.Row="0" x:Name="lblDepPanelBaslik"
                           Text="DEPLASMAN" TextColor="Cyan" FontSize="14"
                           FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Grid.Row="1" x:Name="lblDepOyuncu"
                           Text="🛡️ —" TextColor="#AADDFF" FontSize="12"
                           HorizontalOptions="Center"/>

                    <Button Grid.Row="2" x:Name="btnDep1"
                            Text="—" Clicked="HamleDepClicked"
                            FontSize="19" FontAttributes="Bold" TextColor="White"
                            BackgroundColor="#2A4A2A" CornerRadius="8"
                            HeightRequest="60" Padding="0"/>
                    <Button Grid.Row="3" x:Name="btnDep2"
                            Text="—" Clicked="HamleDepClicked"
                            FontSize="19" FontAttributes="Bold" TextColor="White"
                            BackgroundColor="#2A3A4A" CornerRadius="8"
                            HeightRequest="60" Padding="0"/>
                    <Button Grid.Row="4" x:Name="btnDep3"
                            Text="—" Clicked="HamleDepClicked"
                            FontSize="19" FontAttributes="Bold" TextColor="White"
                            BackgroundColor="#8B1A1A" CornerRadius="8"
                            HeightRequest="65" Padding="0"/>
                </Grid>
            </Grid>

            <!-- PENALTİ PANELİ -->
            <Grid x:Name="pnlPenalti" IsVisible="False"
                  RowDefinitions="Auto, Auto, *" RowSpacing="10">
                <Label Grid.Row="0" x:Name="lblPenaltiBaslik"
                       Text="⚡ PENALTİ ATIŞI"
                       TextColor="Gold" FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Grid.Row="1" x:Name="lblPenaltiDurum"
                       Text="Skor: 0-0 | Tur 1/5"
                       TextColor="White" FontSize="14" HorizontalOptions="Center"/>
                <Grid Grid.Row="2" ColumnDefinitions="*, *, *" ColumnSpacing="10">
                    <Button Grid.Column="0" Text="◀ SOL"
                            Clicked="OnPenaltiYonClicked"
                            FontSize="18" FontAttributes="Bold"
                            BackgroundColor="#2A5C8A" TextColor="White"
                            CornerRadius="12" HeightRequest="80" Padding="0"/>
                    <Button Grid.Column="1" Text="⬆ ORTA"
                            Clicked="OnPenaltiYonClicked"
                            FontSize="18" FontAttributes="Bold"
                            BackgroundColor="#2A5C2A" TextColor="White"
                            CornerRadius="12" HeightRequest="80" Padding="0"/>
                    <Button Grid.Column="2" Text="SAĞ ▶"
                            Clicked="OnPenaltiYonClicked"
                            FontSize="18" FontAttributes="Bold"
                            BackgroundColor="#8A2A2A" TextColor="White"
                            CornerRadius="12" HeightRequest="80" Padding="0"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
