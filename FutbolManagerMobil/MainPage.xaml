<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FutbolManagerMobil"
             x:Class="FutbolManagerMobil.MainPage"
             BackgroundColor="#121212"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="1.2*, 5.5*, 3.3*" Padding="10" RowSpacing="5">
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, *" BackgroundColor="#1A1A1A" Padding="5,2">

            <Label Grid.Column="0" x:Name="lblEvTakimAd" Text="EV" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>

            <Label Grid.Column="1" x:Name="lblSkor" Text="0 - 0" TextColor="White" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>

            <Grid Grid.Column="2">
                <Label x:Name="lblDepTakimAd" Text="DEP" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                <Label x:Name="lblDakika" Text="1:00" TextColor="Gold" FontSize="14" FontAttributes="Bold" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,10,0"/>
            </Grid>

        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="2*, 1*" ColumnSpacing="5">

            <Grid Grid.Column="0">
                <Border Stroke="White" StrokeThickness="1" BackgroundColor="#1E5D1E">
                    <GraphicsView x:Name="sahaGrafik"/>
                </Border>
                <Grid ColumnDefinitions="*,*,*,*,*,*,*" VerticalOptions="End" HeightRequest="16" Background="#80000000">
                    <Label Text="K" Grid.Column="0" HorizontalOptions="Center" TextColor="White" FontSize="8"/>
                    <Label Text="D" Grid.Column="1" HorizontalOptions="Center" TextColor="White" FontSize="8"/>
                    <Label Text="DOS" Grid.Column="2" HorizontalOptions="Center" TextColor="White" FontSize="8"/>
                    <Label Text="MOS" Grid.Column="3" HorizontalOptions="Center" TextColor="White" FontSize="8"/>
                    <Label Text="OOS" Grid.Column="4" HorizontalOptions="Center" TextColor="White" FontSize="8"/>
                    <Label Text="F" Grid.Column="5" HorizontalOptions="Center" TextColor="White" FontSize="8"/>
                    <Label Text="K" Grid.Column="6" HorizontalOptions="Center" TextColor="White" FontSize="8"/>
                </Grid>
            </Grid>

            <Border Grid.Column="1" Background="#F8F9FA" Padding="5" StrokeShape="RoundRectangle 8">
                <ScrollView x:Name="scrSpiker">
                    <VerticalStackLayout x:Name="slSpiker" Spacing="2">
                        <Label x:Name="lblSpiker" Text="Spiker: Hazır." TextColor="DarkBlue" FontSize="11" FontAttributes="Italic" LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="10">

            <Grid Grid.Column="0" RowDefinitions="Auto, Auto, *, *, *" RowSpacing="3">
                <Label Grid.Row="0" x:Name="lblHucumBaslik" Text="HÜCUM" TextColor="Gold" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Grid.Row="1" x:Name="lblAktifOyuncu" Text="Oyuncu..." TextColor="White" FontSize="10" HorizontalOptions="Center" Margin="0,0,0,2"/>
                <Button Grid.Row="2" x:Name="btnKisaPas" Text="PAS" Clicked="HamleYap" FontSize="11" BackgroundColor="#333" CornerRadius="5" Padding="0" MinimumHeightRequest="20"/>
                <Button Grid.Row="3" x:Name="btnAraPasi" Text="ARA PAS" Clicked="HamleYap" FontSize="11" BackgroundColor="#333" CornerRadius="5" Padding="0" MinimumHeightRequest="20"/>
                <Button Grid.Row="4" x:Name="btnSutCek" Text="ŞUT" Clicked="HamleYap" FontSize="11" BackgroundColor="#E74C3C" FontAttributes="Bold" CornerRadius="5" Padding="0" MinimumHeightRequest="20"/>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto, Auto, *, *, *" RowSpacing="3">
                <Label Grid.Row="0" x:Name="lblSavunmaBaslik" Text="SAVUNMA" TextColor="Cyan" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Grid.Row="1" Text=" " FontSize="10" Margin="0,0,0,2"/>
                <Button Grid.Row="2" x:Name="btnPress" Text="PRESS" Clicked="HamleYap" FontSize="11" BackgroundColor="#222" CornerRadius="5" Padding="0" MinimumHeightRequest="20"/>
                <Button Grid.Row="3" x:Name="btnTopaKay" Text="KAY" Clicked="HamleYap" FontSize="11" BackgroundColor="#222" CornerRadius="5" Padding="0" MinimumHeightRequest="20"/>
                <Button Grid.Row="4" x:Name="btnMarkaj" Text="MARKAJ" Clicked="HamleYap" FontSize="11" BackgroundColor="#222" CornerRadius="5" Padding="0" MinimumHeightRequest="20"/>
            </Grid>

        </Grid>
    </Grid>
</ContentPage>